<Window x:Class="ExIptv.Views.SourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quelle hinzufügen" Width="520"
        SizeToContent="Height" MinHeight="420" MaxHeight="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>   <!-- Eingabebereich: Auto, damit SizeToContent exakt rechnet -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Neue Quelle" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Name -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Anzeigename (optional)" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Modus-Umschalter -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <RadioButton x:Name="ModeAuto" Content="URL / Datei (automatisch)" IsChecked="True"
                         Foreground="{StaticResource TextBrush}" GroupName="mode"
                         Checked="ModeAuto_Checked" VerticalContentAlignment="Center"/>
            <RadioButton x:Name="ModeXtream" Content="Xtream manuell" Margin="20,0,0,0"
                         Foreground="{StaticResource TextBrush}" GroupName="mode"
                         Checked="ModeXtream_Checked" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Eingabebereich -->
        <Grid Grid.Row="3">
            <!-- Auto-Modus -->
            <StackPanel x:Name="AutoPanel">
                <TextBlock Text="M3U-URL, get.php-Link oder lokaler Dateipfad"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding UrlOrPath, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" Height="70" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="Beispiel: http://server.tld:8080/get.php?username=...&amp;password=...&amp;type=m3u_plus"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Xtream-Modus -->
            <StackPanel x:Name="XtreamPanel" Visibility="Collapsed">
                <TextBlock Text="Server (Host inkl. Port)" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Benutzername" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Passwort" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordField" PasswordChanged="PasswordField_PasswordChanged"/>
            </StackPanel>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                   TextWrapping="Wrap" Margin="0,14,0,10" MinHeight="20"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Verbindung testen" Style="{StaticResource FlatButton}"
                    Command="{Binding TestCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}" Margin="0,0,8,0"/>
            <Button Content="Abbrechen" Style="{StaticResource FlatButton}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/>
            <Button Content="Hinzufügen" Style="{StaticResource AccentButton}"
                    Command="{Binding OkCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
