<Window x:Class="ExIptv.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="EX-IPTV Desktop" Height="760" Width="1240"
        MinHeight="560" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/app_icon.png"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Hauptbereich -->
            <RowDefinition Height="Auto"/>   <!-- Statusleiste -->
        </Grid.RowDefinitions>

        <!-- ===== Toolbar ===== -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="12,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Assets/logo_small.png" Height="30" VerticalAlignment="Center"
                       Margin="4,0,20,0" RenderOptions.BitmapScalingMode="HighQuality"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding Sources}"
                          SelectedItem="{Binding SelectedSource}" VerticalAlignment="Center"
                          DisplayMemberPath="Name"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button Content="+ Quelle" Style="{StaticResource AccentButton}"
                            Command="{Binding AddSourceCommand}" Margin="0,0,6,0"/>
                    <Button Content="Aktualisieren" Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshSourceCommand}"
                            IsEnabled="{Binding HasSource}" Margin="0,0,6,0"/>
                    <Button Content="Löschen" Style="{StaticResource FlatButton}"
                            Command="{Binding DeleteSourceCommand}"
                            IsEnabled="{Binding HasSource}"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                 Background="Transparent" Foreground="{StaticResource AccentBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Hauptbereich: 3 Spalten ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>   <!-- Kategorien -->
                <ColumnDefinition Width="340"/>   <!-- Inhalte -->
                <ColumnDefinition Width="*"/>     <!-- Player -->
            </Grid.ColumnDefinitions>

            <!-- Kein-Quelle-Hinweis (über alles gelegt) -->
            <Border Grid.ColumnSpan="3" Panel.ZIndex="10" Background="{StaticResource BgBrush}"
                    Visibility="{Binding HasSource, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="360" HorizontalAlignment="Center"
                           Margin="0,0,0,28" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Keine Quelle vorhanden" FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Füge einen Xtream-Zugang oder eine M3U-Playlist hinzu, um zu starten."
                               Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="+ Quelle hinzufügen" Style="{StaticResource AccentButton}"
                            Command="{Binding AddSourceCommand}" HorizontalAlignment="Center" Padding="18,10"/>
                </StackPanel>
            </Border>

            <!-- Spalte 1: Sektionen + Kategorien -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,10">
                        <RadioButton Content="Live" Style="{StaticResource SectionButton}"
                                     IsChecked="True" Command="{Binding ShowLiveCommand}"/>
                        <RadioButton Content="Filme" Style="{StaticResource SectionButton}"
                                     Command="{Binding ShowMoviesCommand}"/>
                        <RadioButton Content="Serien" Style="{StaticResource SectionButton}"
                                     Command="{Binding ShowSeriesCommand}"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top" Text="KATEGORIEN" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" Margin="14,6,0,6"/>

                    <ListBox Style="{StaticResource CleanListBox}"
                             ItemContainerStyle="{StaticResource RowItem}"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             Margin="6,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ItemCount}"
                                               Foreground="{StaticResource TextDimBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Spalte 2: Suche + Inhaltsliste (mit Episoden-Overlay, rein WPF – kein Airspace-Konflikt) -->
            <Border Grid.Column="1" Background="{StaticResource BgBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <!-- Inhaltsliste -->
                    <DockPanel Margin="10">
                        <TextBox DockPanel.Dock="Top" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"
                                 Tag="Suchen…"/>
                        <ListBox Style="{StaticResource CleanListBox}"
                                 ItemContainerStyle="{StaticResource RowItem}"
                                 ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem}"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ListBox.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding ActivateItemCommand}"
                                              CommandParameter="{Binding SelectedItem}"/>
                            </ListBox.InputBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextDimBrush}"
                                                       FontSize="11"
                                                       Visibility="{Binding Subtitle, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="›" FontSize="16"
                                                   Foreground="{StaticResource TextDimBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsSeriesContainer, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Episoden-Ansicht (überlagert die Inhaltsliste bei Serienauswahl) -->
                    <Border Background="{StaticResource BgBrush}"
                            Visibility="{Binding ShowEpisodes, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="10">
                            <Button DockPanel.Dock="Top" Content="‹ Zurück" Style="{StaticResource FlatButton}"
                                    HorizontalAlignment="Left" Command="{Binding CloseEpisodesCommand}"
                                    Margin="0,0,0,8"/>
                            <TextBlock DockPanel.Dock="Top" Text="{Binding EpisodesTitle}" FontSize="15"
                                       FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="2,0,0,10"/>
                            <ListBox Style="{StaticResource CleanListBox}"
                                     ItemContainerStyle="{StaticResource RowItem}"
                                     ItemsSource="{Binding Episodes}"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayEpisodeCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Spalte 3: Player -->
            <Grid Grid.Column="2" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- VideoView -->
                <vlc:VideoView x:Name="VideoView" Grid.Row="0"/>

                <!-- Platzhalter, wenn nichts läuft -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                            IsHitTestVisible="False">
                    <TextBlock Text="▶" FontSize="52" Foreground="#FF3A4150" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sender oder Titel doppelklicken zum Abspielen"
                               Foreground="#FF556070" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Player-Leiste -->
                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="⏯" Style="{StaticResource FlatButton}" FontSize="16"
                                    Command="{Binding TogglePauseCommand}" Margin="0,0,6,0" Padding="14,4"/>
                            <Button Content="⏹" Style="{StaticResource FlatButton}" FontSize="16"
                                    Command="{Binding StopPlaybackCommand}" Padding="14,4"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                            <TextBlock Text="{Binding NowPlaying}" TextTrimming="CharacterEllipsis"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding PlayerStatus}" Foreground="{StaticResource TextDimBrush}"
                                       FontSize="11"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔊" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider Width="110" Minimum="0" Maximum="100"
                                    Value="{Binding Volume}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Statusleiste ===== -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" Padding="14,6"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextDimBrush}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
