<Window x:Class="ExIptv.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Width="600" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Abschnittsüberschrift -->
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,18,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <!-- Farbfeld-Auswahl -->
        <Style x:Key="SwatchList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Outer" CornerRadius="6" Padding="2"
                                            BorderThickness="2" BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Outer" Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Puffer -->
                <TextBlock Style="{StaticResource Section}" Text="Puffer"/>
                <TextBlock Style="{StaticResource Label}"
                           Text="{Binding NetworkCachingMs, StringFormat='Netzwerk-Puffer (Filme/Serien): {0} ms'}"/>
                <Slider Minimum="0" Maximum="8000" TickFrequency="250" IsSnapToTickEnabled="True"
                        Value="{Binding NetworkCachingMs}"/>
                <TextBlock Style="{StaticResource Label}"
                           Text="{Binding LiveCachingMs, StringFormat='Live-Puffer: {0} ms'}"/>
                <Slider Minimum="0" Maximum="8000" TickFrequency="250" IsSnapToTickEnabled="True"
                        Value="{Binding LiveCachingMs}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="Größerer Puffer = weniger Abbrüche, aber höhere Verzögerung beim Umschalten."/>

                <!-- Stabilisierung -->
                <TextBlock Style="{StaticResource Section}" Text="Stabilisierung"/>
                <CheckBox Content="Automatisch neu verbinden bei Abbruch"
                          Foreground="{DynamicResource TextBrush}" Margin="0,4"
                          IsChecked="{Binding AutoReconnect}"/>
                <CheckBox Content="HTTP-Wiederverbindung (empfohlen)"
                          Foreground="{DynamicResource TextBrush}" Margin="0,4"
                          IsChecked="{Binding HttpReconnect}"/>
                <CheckBox Content="Zusätzlicher Datei-Puffer für Filme/Serien"
                          Foreground="{DynamicResource TextBrush}" Margin="0,4"
                          IsChecked="{Binding FileCaching}"/>
                <TextBlock Style="{StaticResource Label}"
                           Text="{Binding MaxReconnectAttempts, StringFormat='Maximale Neuverbindungs-Versuche: {0}'}"/>
                <Slider Minimum="0" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding MaxReconnectAttempts}"/>

                <!-- Wiedergabeweg -->
                <TextBlock Style="{StaticResource Section}" Text="Wiedergabeweg"/>
                <ComboBox
                          ItemsSource="{Binding PlaybackModes}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding PlaybackMode}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="„Immer umwandeln“ nutzt reine Software-Dekodierung für maximale Kompatibilität (höhere CPU-Last)."/>

                <!-- Bild -->
                <TextBlock Style="{StaticResource Section}" Text="Bild"/>
                <TextBlock Style="{StaticResource Label}" Text="Bildverbesserung"/>
                <ComboBox
                          ItemsSource="{Binding ImageQualities}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding ImageQuality}"/>
                <TextBlock Style="{StaticResource Label}" Text="Bildrate"/>
                <ComboBox
                          ItemsSource="{Binding FrameRates}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding FrameRateMode}"/>
                <CheckBox Content="Deinterlacing (bei Zeilenflimmern)"
                          Foreground="{DynamicResource TextBrush}" Margin="0,8,0,0"
                          IsChecked="{Binding Deinterlace}"/>

                <!-- Player-Profile -->
                <TextBlock Style="{StaticResource Section}" Text="Player-Profil je Inhaltstyp"/>
                <TextBlock Style="{StaticResource Label}" Text="Live-TV"/>
                <ComboBox
                          ItemsSource="{Binding Profiles}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding LiveProfile}"/>
                <TextBlock Style="{StaticResource Label}" Text="Filme"/>
                <ComboBox
                          ItemsSource="{Binding Profiles}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding MovieProfile}"/>
                <TextBlock Style="{StaticResource Label}" Text="Serien"/>
                <ComboBox
                          ItemsSource="{Binding Profiles}" DisplayMemberPath="Label"
                          SelectedValuePath="Value" SelectedValue="{Binding SeriesProfile}"/>
                <TextBlock Style="{StaticResource Hint}"
                           Text="Fünf Decode-Profile derselben Engine (LibVLC). Bei schwarzem Bild „Software“ oder „Kompatibilität“ wählen."/>

                <!-- EPG -->
                <TextBlock Style="{StaticResource Section}" Text="Programm-Guide (EPG)"/>
                <TextBlock Style="{StaticResource Label}"
                           Text="{Binding EpgOffsetHours, StringFormat='Zeitversatz: +{0} Stunden'}"/>
                <Slider Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding EpgOffsetHours}"/>

                <!-- Hintergrundfarbe -->
                <TextBlock Style="{StaticResource Section}" Text="Hintergrundfarbe der Oberfläche"/>
                <ListBox Style="{StaticResource SwatchList}"
                         ItemsSource="{Binding Backgrounds}"
                         SelectedValuePath="Key" SelectedValue="{Binding SelectedBackgroundKey}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="52" Height="34" CornerRadius="4" Background="{Binding Brush}"
                                    ToolTip="{Binding Name}" BorderThickness="1" BorderBrush="#33FFFFFF"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Schriftfarbe -->
                <TextBlock Style="{StaticResource Section}" Text="Schriftfarbe"/>
                <ListBox Style="{StaticResource SwatchList}"
                         ItemsSource="{Binding TextColors}"
                         SelectedValuePath="Key" SelectedValue="{Binding SelectedTextKey}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="52" Height="34" CornerRadius="4" Background="#20FFFFFF"
                                    ToolTip="{Binding Name}" BorderThickness="1" BorderBrush="#33FFFFFF">
                                <TextBlock Text="Aa" FontWeight="SemiBold" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{Binding Brush}"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Abbrechen" Style="{StaticResource FlatButton}" Width="110" Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Speichern" Style="{StaticResource AccentButton}" Width="130"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
