<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BackgroundColor">#121417</Color>
    <Color x:Key="SurfaceColor">#1B1E23</Color>
    <Color x:Key="AccentDarkBlue">#1F3864</Color>
    <Color x:Key="AccentMidBlue">#2E75B6</Color>
    <Color x:Key="TextPrimary">#F2F2F2</Color>
    <Color x:Key="TextSecondary">#9AA0A6</Color>
    <Color x:Key="ErrorColor">#D64545</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="AccentDarkBlueBrush" Color="{StaticResource AccentDarkBlue}" />
    <SolidColorBrush x:Key="AccentMidBlueBrush" Color="{StaticResource AccentMidBlue}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

</ResourceDictionary>
