git clone https://github.com/EjupXhemajli/DESKTOPiptv.git
cd DESKTOPiptv/ExIptvDesktop

# Inhalte der doppelt verschachtelten Ebene eine Stufe hochziehen
mv ExIptvDesktop/* .
mv ExIptvDesktop/.github .   # falls .github nicht von mv * erfasst wird (versteckter Ordner)
rmdir ExIptvDesktop

# Zip-Datei aus dem Repo entfernen
git rm --cached ExIptvDesktop.zip
rm ExIptvDesktop.zip

git add -A
git commit -m "Fix: doppelte Ordnerverschachtelung entfernt, Zip aus Repo entfernt"
git push
